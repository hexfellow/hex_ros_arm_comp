<launch>
    <!-- simulation arguments -->
    <arg name="viewer" default="true"/>
    <arg name="rviz" default="true"/>

    <!-- sim environment (mujoco + rviz, no built-in test ctrl) -->
    <include file="$(find hex_ros_sim_archer_y6)/launch/ros1/sim_archer_y6.launch">
        <arg name="viewer" value="$(arg viewer)"/>
        <arg name="rviz" value="$(arg rviz)"/>
        <arg name="test" value="false"/>
    </include>

    <!-- keyboard teleop -->
    <include file="$(find hex_ros_teleop_keyboard)/launch/ros1/teleop_keyboard.launch"/>

    <!-- gravity compensation node -->
    <include file="$(find hex_ros_arm_comp)/launch/ros1/arm_comp.launch"/>
</launch>
