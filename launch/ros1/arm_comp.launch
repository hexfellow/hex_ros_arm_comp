<launch>
    <node name="arm_comp" pkg="hex_ros_arm_comp" type="arm_comp.py" output="screen">
        <!-- load default parameters -->
        <rosparam file="$(find hex_ros_arm_comp)/config/ros1/params.yaml"/>
        <!-- robot model used for dynamics -->
        <param name="model_urdf" value="$(find hex_ros_urdf_archer_y6)/urdf/gr100_comp.urdf"/>
        <!-- subscribe -->
        <remap from="manip_state" to="manip_state"/>
        <remap from="teleop_keyboard_state" to="teleop_keyboard_state"/>
        <!-- publish -->
        <remap from="manip_ctrl" to="manip_ctrl"/>
    </node>
</launch>
